<playercorefactory>
  <players>
    <player name="VLC" type="ExternalPlayer" audio="true" video="true">
      <filename>C:\Program Files\VideoLAN\VLC\vlc.exe</filename>
      <args>"{1}" /fullscreen</args>
      <hidexbmc>true</hidexbmc>
    </player>
    <player name="MPC-HC" type="ExternalPlayer" audio="true" video="true">
      <filename>E:\Program Files (x86)\K-Lite Codec Pack\MPC-HC64\mpc-hc64.exe</filename>
      <args>"{1}" /fullscreen</args>
      <hidexbmc>true</hidexbmc>
    </player>
  </players>
  
  <rules action="prepend">
    <!-- Use VLC for internet streams -->
    <rule internetstream="true"  player="VLC" />
    <!-- Use MPC-HC for internet streams -->
    <rule internetstream="true" player="MPC-HC" />
  </rules>
</playercorefactory>
